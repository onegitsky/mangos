{
    "layer": "top",
    "position": "top",
    "output": "DP-1",
    "height": 21,
    "modules-left": ["ext/workspaces","custom/playerctl"],
    "modules-center": ["dwl/window"],
    "modules-right": ["pulseaudio","clock#time","custom/notification","tray"],
    
    "ext/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
            "1": "一",
            "2": "二",
            "3": "三",
            "4": "四",
            "5": "五",
            "6": "六",
            "7": "七",
            "8": "八",
            "9": "九",
            "10": "十",
            "urgent": "",
            "default": ""
        }
    },
    "dwl/window": {
        "format": "{}",
        "max-length": 40,
        "tooltip": false,
        "all-outputs": true,
        "icon": false
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "",
            "none": "",
            "dnd-notification": "",
            "dnd-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "tray": {
        "icon-size": 14,
        "spacing": 4
    },
    "clock#time": {
        "interval": "1",
        "format": "{:%H:%M}",
        "tooltip": false,
        "on-click": "foot --title calcurse -c ~/.config/foot/foot.ini -e calcurse",
        "on-click-right": "foot --title weather -c ~/.config/foot/foot.ini -e sh -c 'curl wttr.in; echo; read -n 1 -s -r -p \"Press any key to close\"'"
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}     {volume:2}% {format_source}",
        "format-muted": "  {format_source}",
        "format-source": "<span color=\"#ebebeb\">  {volume:2}%</span>",
        "format-source-muted": "<span color=\"#4c566a\"></span>",
        "max-volume": 100,
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "on-click": "foot --title pulsemixer -c ~/.config/foot/foot.ini -e pulsemixer",
        "tooltip": false
    },
    "custom/playerctl": {
        "exec": "~/.config/waybar/custom_modules/media-player-status.py --player=mpd",
        "return-type": "json",
        "on-click": "playerctl -p mpd play-pause",
        "on-click-middle": "~/.local/bin/waybar-scripts/spot-skip.py && playerctl -p mpd next",
        "on-click-right": "~/.local/bin/waybar-scripts/fzf-search.sh",
        "on-scroll-up": "~/.local/bin/waybar-scripts/mpd-volume.sh up",
        "on-scroll-down": "~/.local/bin/waybar-scripts/mpd-volume.sh down",
        "tooltip": false
    }
}
